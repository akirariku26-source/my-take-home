# Rename to .env and fill in any keys your solution needs.
# We have accounts with these providers and will supply real keys when reviewing.

ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
ELEVEN_LABS_API_KEY=xxxxx
GOOGLE_CLOUD_API_KEY=xxxxx
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-west-2

# ── TTS API configuration ─────────────────────────────────────────────────────
# All settings are prefixed with TTS_ and have sensible defaults.
# Override only what you need.
#
# This file is the single source of truth for all configuration.
# Copy to .env and adjust values for your environment.
# When running via docker-compose, only the Redis URLs are overridden inline
# (docker-compose uses the "redis" service name instead of localhost).

# TTS backend: "kokoro" (default) | "mock" (for testing)
TTS_BACKEND=kokoro

# Kokoro language code: "a" = American English, "b" = British English
TTS_KOKORO_LANG_CODE=a

# Default voice (see GET /v1/voices for full list)
TTS_DEFAULT_VOICE=af_heart

# Worker threads for TTS inference (CPU-bound, match physical CPU cores)
TTS_MAX_WORKERS=4

# ── Job queue (Celery + Redis) ─────────────────────────────────────────────────
# Set to true when running with Redis + Celery workers for durable burst handling.
# docker-compose overrides the URLs below to use the "redis" service name.
TTS_QUEUE_ENABLED=false
TTS_CELERY_BROKER_URL=redis://localhost:6379/0
TTS_CELERY_RESULT_BACKEND_URL=redis://localhost:6379/0

# ── Adaptive concurrency control ──────────────────────────────────────────────
TTS_ADAPTIVE_CONCURRENCY_ENABLED=true
# Starting window size (0 = auto: TTS_MAX_WORKERS * 2)
TTS_ADAPTIVE_CONCURRENCY_INITIAL=0
# EWMA latency target in seconds — window shrinks when exceeded
TTS_ADAPTIVE_CONCURRENCY_TARGET_LATENCY_S=10.0

# ── Audio cache ────────────────────────────────────────────────────────────────
TTS_CACHE_ENABLED=true
TTS_CACHE_MAX_SIZE=1000
TTS_CACHE_TTL_SECONDS=3600

# ── Rate limiting (per client IP) ─────────────────────────────────────────────
TTS_RATE_LIMIT_ENABLED=true
TTS_RATE_LIMIT_RPM=60
TTS_RATE_LIMIT_BURST=10

# ── API key authentication ─────────────────────────────────────────────────────
# Comma-separated list of valid keys. Leave empty to disable auth (local dev).
# Example: TTS_API_KEYS=sk-abc123,sk-def456
TTS_API_KEYS=

# ── HuggingFace model cache ────────────────────────────────────────────────────
# Local dev: relative path. Docker: set to /app/.hf_cache (see docker-compose.yml).
HF_HOME=.hf_cache
