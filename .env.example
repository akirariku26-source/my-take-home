# Rename to .env and fill in any keys your solution needs.
# We have accounts with these providers and will supply real keys when reviewing.

ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
ELEVEN_LABS_API_KEY=xxxxx
GOOGLE_CLOUD_API_KEY=xxxxx
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-west-2

# ── TTS API configuration ─────────────────────────────────────────────────────
# All settings are prefixed with TTS_ and have sensible defaults.
# Override only what you need.

# TTS backend: "kokoro" (default) | "mock" (for testing)
TTS_BACKEND=kokoro

# Kokoro language code: "a" = American English, "b" = British English
TTS_KOKORO_LANG_CODE=a

# Default voice (see GET /v1/voices for full list)
TTS_DEFAULT_VOICE=af_heart

# Worker threads for TTS inference (CPU-bound)
TTS_MAX_WORKERS=4

# Audio cache settings
TTS_CACHE_ENABLED=true
TTS_CACHE_MAX_SIZE=1000

# Rate limiting (per client IP)
TTS_RATE_LIMIT_ENABLED=true
TTS_RATE_LIMIT_RPM=60
TTS_RATE_LIMIT_BURST=10

# API key authentication
# Comma-separated list of valid keys. Leave empty to disable auth (local dev).
# Example: TTS_API_KEYS=sk-abc123,sk-def456
TTS_API_KEYS=

# HuggingFace model cache directory (set this to a persistent path in production)
HF_HOME=.hf_cache
